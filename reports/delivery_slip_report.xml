<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <template id="report_delivery_document_inherit_azentra_weights" inherit_id="stock.report_delivery_document">
        
        <xpath expr="//table[@name='stock_move_table']" position="before">
            <style>
                table[name='stock_move_table'] th:not(:first-child), 
                table[name='stock_move_table'] td:not(:first-child),
                table[name='stock_move_line_table'] th:not(:first-child), 
                table[name='stock_move_line_table'] td:not(:first-child) {
                    text-align: center !important;
                    font-weight: normal !important;
                }
                /* Ensure table headers maintain a clean look without explicit bolding */
                table[name='stock_move_table'] thead th,
                table[name='stock_move_line_table'] thead th {
                    font-weight: 600 !important;
                }
            </style>
        </xpath>
        
        <xpath expr="//table[@name='stock_move_table']/thead/tr/th[last()]" position="replace">
            <th class="text-center">Gross weight</th>
            <th class="text-center">Net weight</th>
        </xpath>

        <xpath expr="//table[@name='stock_move_table']/tbody/tr/td[last()]" position="attributes">
            <attribute name="class">text-center</attribute>
        </xpath>

        <xpath expr="//table[@name='stock_move_table']/tbody/tr/td[last()]" position="after">
            <td class="text-center" style="font-weight: normal !important;">
                <span t-out="move.az_net_weight"/>&#160;<span t-out="move.product_uom.name"/>
            </td>
        </xpath>

        <xpath expr="//table[@name='stock_move_line_table']/thead/tr/th[last()]" position="replace">
            <th class="text-center">Gross weight</th>
            <th class="text-center">Net weight</th>
        </xpath>
        
    </template>

    <template id="stock_report_delivery_aggregated_move_lines_inherit_weights" inherit_id="stock.stock_report_delivery_aggregated_move_lines">
        
        <xpath expr="//tr/td[last()]" position="attributes">
            <attribute name="class">text-center</attribute>
        </xpath>

        <xpath expr="//tr/td[last()]" position="after">
            <t t-set="az_move" t-value="o.move_ids.filtered(lambda m: m.product_id == aggregated_lines[line]['product'])[:1]"/>
            <td class="text-center" style="font-weight: normal !important;">
                <span t-out="az_move.az_net_weight"/>&#160;<span t-out="az_move.product_uom.name"/>
            </td>
        </xpath>
        
    </template>
    
</odoo>