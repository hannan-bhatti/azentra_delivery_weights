<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_delivery_document_inherit_azentra_weights" inherit_id="stock.report_delivery_document">
        
        <xpath expr="//table//thead//tr//th[contains(string(), 'Quantity') or contains(string(), 'Ordered')]" position="before">
            <th class="text-center"><strong>G.W</strong></th>
            <th class="text-center"><strong>N.W</strong></th>
        </xpath>

        <xpath expr="//table//tbody//tr//td[span[@t-field='move.quantity'] or span[@t-field='move.product_uom_qty']]" position="before">
            <td class="text-center">
                <span t-field="move.az_gross_weight"/>
            </td>
            <td class="text-center">
                <span t-field="move.az_net_weight"/>
            </td>
        </xpath>
        
    </template>
</odoo>