<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_inherit_azentra_weights" model="ir.ui.view">
        <field name="name">account.move.form.inherit.azentra.weights</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            
            <xpath expr="//field[@name='invoice_line_ids']//field[@name='quantity']" position="attributes">
                <attribute name="string">Gross weight</attribute>
            </xpath>

            <xpath expr="//field[@name='invoice_line_ids']//field[@name='quantity']" position="before">
                <field name="az_net_weight"/>
            </xpath>
            
        </field>
    </record>
</odoo>